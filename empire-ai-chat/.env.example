# Required. Generate a unique random value of at least 32 characters.
CHAT_ACCESS_TOKEN=

# Safe default: reachable only from the same host. Change only behind an
# authenticated reverse proxy and keep CHAT_ACCESS_TOKEN enabled.
CHAT_LISTEN_HOST=127.0.0.1
PORT=8090
CHAT_ALLOWED_ORIGINS=https://example.com

OLLAMA_URL=http://127.0.0.1:11434
EMPIRE_MODEL=llama3.2:1b

# Optional providers. There are no built-in credentials or remote router URLs.
FREE_GROQ_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMPIRE_ROUTER=
EMPIRE_KEY=

# Voice chat (Speech-to-Text & Text-to-Speech)
# STT: Groq Whisper API (requires FREE_GROQ_KEY above)
STT_LANG=hy
# TTS: Piper (local Armenian voice)
PIPER_BIN=/opt/piper-hy/piper/piper
PIPER_MODEL=/opt/piper-hy/hy_AM-gor-medium.onnx
PIPER_CONFIG=/opt/piper-hy/hy_AM-gor-medium.onnx.json

# Private notes are excluded unless this is explicitly enabled.
ENABLE_PRIVATE_BRAIN=false
EMPIRE_BRAIN=/opt/empire-sync/brain.json

# Resource budgets (defaults shown).
CHAT_JSON_BODY_BYTES=131072
CHAT_TTS_BODY_BYTES=16384
CHAT_STT_BODY_BYTES=10485760
CHAT_MAX_MESSAGES=24
CHAT_MAX_ITEM_CHARS=4000
CHAT_MAX_CONTEXT_CHARS=24000
CHAT_MAX_COMPLETION_TOKENS=768
CHAT_MAX_BRAIN_CHARS=6000
CHAT_BODY_TIMEOUT_MS=15000
CHAT_UPSTREAM_TIMEOUT_MS=60000
CHAT_MAX_CONCURRENCY=4
CHAT_STT_MAX_CONCURRENCY=2
CHAT_TTS_MAX_CONCURRENCY=2
