# 6-EMPIRE GitHub Sync — copy to .env on the VPS and fill in your token.
# Create the token at: github.com → Settings → Developer settings →
#   Personal access tokens → Fine-grained tokens → Generate new token
#   • Repository access: Only select repositories → pick your empire repos
#   • Permissions → Repository: Contents (Read-only), Metadata (Read-only), Issues (Read-only)
GITHUB_TOKEN=github_pat_REPLACE_ME
GITHUB_WRITE_TOKEN=
# Required. Generate independently with: openssl rand -hex 32
SYNC_ADMIN_TOKEN=REPLACE_WITH_64_RANDOM_HEX_CHARACTERS
# Required only when the signed /api/empire/webhook endpoint is enabled.
GITHUB_WEBHOOK_SECRET=REPLACE_WITH_A_DIFFERENT_64_RANDOM_HEX_VALUE
GITHUB_OWNER=RolandGasparyan
SYNC_PORT=8120
SYNC_LISTEN_HOST=127.0.0.1
SYNC_ALLOWED_ORIGINS=https://6-empires.com
SYNC_MAX_BODY_BYTES=16384
SYNC_REQUEST_TIMEOUT_MS=10000
SYNC_REPOS=6-empires-os,trading-guru-empire,strategy-lab-mac,dzayn-app,reincarnation-smm,REINCARNATION-Social-media-Gods,vortex,BOOKING-AI-AGENT,founders-kit
