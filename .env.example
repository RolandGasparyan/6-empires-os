# ============ 6-EMPIRE OS — PRODUCTION ENV (copy to .env, fill in) ============
ENV=production

# --- Postgres ---
POSTGRES_USER=empire
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__
POSTGRES_DB=empires
DATABASE_URL=postgresql+asyncpg://empire:__CHANGE_ME_STRONG__@postgres:5432/empires

# --- Redis / Qdrant / Neo4j ---
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=__CHANGE_ME_STRONG__

# --- Security ---
# Generate: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME_64_HEX__
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
FOUNDER_EMAIL=roland.gasparyan@gmail.com

# --- CORS (production domains) ---
CORS_ORIGINS=https://6-empires.com,https://www.6-empires.com,https://chat.6-empires.com

# --- AI / integrations (optional) ---
OPENAI_API_KEY=
OPENHUMAN_CLIENT_ID=
OPENHUMAN_CLIENT_SECRET=

# --- OpenHuman Core runtime ---
# Bearer token presented on every /openhuman/rpc call. Generate a fresh one:
#   openssl rand -hex 32   (then prefix with ohc_)
# This is the value you paste into the "Auth Token (OPENHUMAN_CORE_TOKEN)" field.
OPENHUMAN_CORE_TOKEN=__CHANGE_ME_ohc_64_HEX__
# Saved default for the "Runtime URL" field (the runtime's /rpc endpoint).
OPENHUMAN_RUNTIME_URL=
