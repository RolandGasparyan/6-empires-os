{
  "name": "empire-assistant",
  "productName": "EMPIRE Assistant",
  "version": "1.0.0",
  "description": "6-EMPIRE OS — voice + chat AI assistant (EMPIRE brain)",
  "main": "main.js",
  "author": "6-EMPIRE",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.6empire.assistant",
    "productName": "EMPIRE Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "empire-logo.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
